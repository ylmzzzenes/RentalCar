@using RentalCar.Domain.Entities
@using RentalCar.Domain.Enums
@model List<RentalCar.Domain.Entities.Car>
@{
    var reliabilityScores = ViewBag.ReliabilityScores as IDictionary<int, RentalCar.Application.Contracts.Cars.ListingReliabilityResult>;
    var recommendedCars = ViewBag.RecommendedCars as List<RentalCar.Domain.Entities.Car> ?? new();
}

<div class="row">
  
    <div class="col-md-3 mb-4">
        <div class="listing-filter-panel shadow-sm p-4">
            <h5 class="fw-bold mb-4 text-secondary text-center">🔍 Araç Filtrele</h5>

            <form method="get" asp-controller="CarBrowse"" asp-controller="CarBrowse" asp-action="List" class="needs-validation" novalidate>
                @if (ViewBag.PostedBy is string pb && !string.IsNullOrWhiteSpace(pb))
                {
                    <input type="hidden" name="postedBy" value="@pb" />
                }
                <input type="text" name="searchString" value="@ViewBag.SearchString" class="form-control form-control-sm mb-3 shadow-sm" placeholder="Genel arama" />
                <input type="text" name="brand" value="@ViewBag.Brand" class="form-control form-control-sm mb-3 shadow-sm" placeholder="Marka" />
                <input type="text" name="model" value="@ViewBag.Model" class="form-control form-control-sm mb-3 shadow-sm" placeholder="Model" />
                <input type="text" name="renk" value="@ViewBag.Renk" class="form-control form-control-sm mb-3 shadow-sm" placeholder="Renk" />
                <input type="text" name="city" value="@ViewBag.City" class="form-control form-control-sm mb-3 shadow-sm" placeholder="Şehir" />

                <select name="yakitTuru" class="form-select form-select-sm mb-3 shadow-sm">
                    <option value="">Yakıt Türü</option>
                    @foreach (var fuel in Enum.GetValues(typeof(FuelType)).Cast<FuelType>())
                    {
                        <option value="@fuel" selected="@(string.Equals(ViewBag.YakitTuru as string, fuel.ToString(), StringComparison.OrdinalIgnoreCase))">@fuel.GetDisplayName()</option>
                    }
                </select>

                <select name="vites" class="form-select form-select-sm mb-3 shadow-sm">
                    <option value="">Vites Türü</option>
                    @foreach (var g in Enum.GetValues(typeof(Gear)).Cast<Gear>())
                    {
                        <option value="@g" selected="@(string.Equals(ViewBag.Vites as string, g.ToString(), StringComparison.OrdinalIgnoreCase))">@g.GetDisplayName()</option>
                    }
                </select>

                <select name="bodyType" class="form-select form-select-sm mb-3 shadow-sm">
                    <option value="">Kasa Tipi</option>
                    @foreach (var body in Enum.GetValues(typeof(BodyType)).Cast<BodyType>())
                    {
                        <option value="@body" selected="@(string.Equals(ViewBag.BodyType as string, body.ToString(), StringComparison.OrdinalIgnoreCase))">@body.GetDisplayName()</option>
                    }
                </select>

                <input type="number" name="yil" value="@ViewBag.Yil" class="form-control form-control-sm mb-3 shadow-sm" placeholder="Yıl (tam eşleşme)" />
                <input type="number" name="minYil" value="@ViewBag.MinYil" class="form-control form-control-sm mb-3 shadow-sm" placeholder="Min yıl" />
                <input type="number" name="maxYil" value="@ViewBag.MaxYil" class="form-control form-control-sm mb-3 shadow-sm" placeholder="Max yıl" />
                <input type="number" name="minKm" value="@ViewBag.MinKm" class="form-control form-control-sm mb-3 shadow-sm" placeholder="Min km" />
                <input type="number" name="maxKm" value="@ViewBag.MaxKm" class="form-control form-control-sm mb-3 shadow-sm" placeholder="Max km" />
                <input type="number" step="1000" name="minFiyat" value="@ViewBag.MinFiyat" class="form-control form-control-sm mb-3 shadow-sm" placeholder="Min fiyat" />
                <input type="number" step="1000" name="maxFiyat" value="@ViewBag.MaxFiyat" class="form-control form-control-sm mb-4 shadow-sm" placeholder="Max fiyat" />

                <button class="btn btn-warning w-100 fw-semibold shadow-sm btn-sm">Filtrele</button>
            </form>
        </div>
    </div>



    <div class="col-md-9">
        @if (ViewBag.PostedBy is string sellerId && !string.IsNullOrWhiteSpace(sellerId))
        {
            <div class="alert glass-alert border-0 shadow-sm mb-3 d-flex flex-wrap align-items-center justify-content-between gap-2">
                <span><strong>Satıcı filtresi:</strong> Bu üyenin onaylı ilanları listeleniyor.</span>
                <a asp-controller="CarBrowse" asp-action="List" class="btn btn-sm btn-outline-light">Filtreyi kaldır</a>
            </div>
        }
        @if (recommendedCars.Count > 0)
        {
            <div class="alert alert-info border-0 shadow-sm py-2 mb-3">
                <strong>LLM Önerileri:</strong> Filtre kriterlerine göre ek önerilen araçlar aşağıda.
            </div>
            <div class="row row-cols-1 row-cols-md-2 g-3 mb-4">
                @foreach (var suggested in recommendedCars)
                {
                    <div class="col">
                        <div class="card border-0 shadow-sm">
                            <div class="card-body py-2">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <div class="fw-semibold">@(suggested.CatalogBrand ?? suggested.Brand) @suggested.Model</div>
                                        <small class="text-muted">@(suggested.ModelYear?.ToString() ?? "-") | @(suggested.ListedPrice?.ToString("N0") ?? "0") TL</small>
                                    </div>
                                    <a asp-controller="CarBrowse" asp-action="Details" asp-route-id="@suggested.Id" class="btn btn-outline-primary btn-sm">İncele</a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        @if (Model != null && Model.Any())
        {
            <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-3">
                @foreach (var car in Model)
                {
                    <div class="col">
                        <div class="card listing-card h-100 shadow-sm border-0 rounded-4">
                            <div id="carCarousel-@car.Id" class="carousel slide" data-bs-ride="carousel">
                                <div class="carousel-inner">
                                    @{
                                        var images = car.ImageUrls?.Where(x => !string.IsNullOrWhiteSpace(x)).Select(x => x.Trim()).ToArray() ?? Array.Empty<string>();
                                        if (images.Length == 0)
                                        {
                                            images = ["https://via.placeholder.com/640x360?text=Arac+Gorseli"];
                                        }
                                        for (int i = 0; i < images.Length; i++)
                                        {
                                            <div class="carousel-item @(i == 0 ? "active" : "")">
                                                <img src="@(images[i].StartsWith("http", StringComparison.OrdinalIgnoreCase) ? images[i] : Url.Content($"~/Images/Upload/{images[i]}"))"
                                                     class="d-block w-100 img-fluid rounded-top"
                                                     alt="@car.Brand @car.Model"
                                                     style="height: 160px; object-fit: cover;" />
                                            </div>
                                        }
                                    }
                                </div>
                                <button class="carousel-control-prev" type="button" data-bs-target="#carCarousel-@car.Id" data-bs-slide="prev">
                                    <span class="carousel-control-prev-icon"></span>
                                    <span class="visually-hidden">Önceki</span>
                                </button>
                                <button class="carousel-control-next" type="button" data-bs-target="#carCarousel-@car.Id" data-bs-slide="next">
                                    <span class="carousel-control-next-icon"></span>
                                    <span class="visually-hidden">Sonraki</span>
                                </button>
                            </div>

                            <div class="card-body py-3 px-3">
                                <h6 class="card-title fw-semibold mb-2 text-dark small">@(car.CatalogBrand ?? car.Brand) @car.Model</h6>
                                <p class="card-text text-muted small mb-2">
                                    Renk: @car.Color<br />
                                    Yıl: @(car.ModelYear)
                                </p>
                                <div class="listing-price mb-2">
                                    @(car.ListedPrice.HasValue ? $"{car.ListedPrice.Value:N0} TL" : "Fiyat bilgisi yok")
                                </div>
                                @if (reliabilityScores is not null && reliabilityScores.TryGetValue(car.Id, out var trust))
                                {
                                    <div class="mb-2 small">
                                        <span class="badge @(trust.Label == "High" ? "bg-success" : trust.Label == "Medium" ? "bg-warning text-dark" : "bg-danger")">
                                            @trust.TrustLevelTr · @trust.Score/100
                                        </span>
                                        @if (!string.IsNullOrWhiteSpace(trust.UserExplanation))
                                        {
                                            <div class="text-muted mt-1" style="font-size: 0.78rem; line-height: 1.35;">@trust.UserExplanation</div>
                                        }
                                    </div>
                                }
                                <div class="d-grid gap-2">
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <a asp-controller="CarBrowse" asp-action="Details" asp-route-id="@car.Id" class="btn btn-outline-primary btn-sm">Detaylar</a>
                                        <a asp-controller="CarManagement" asp-action="Edit" asp-route-id="@car.Id" class="btn btn-outline-secondary btn-sm">Güncelle</a>
                                        <a asp-controller="CarManagement" asp-action="Delete" asp-route-id="@car.Id" class="btn btn-outline-danger btn-sm">Sil</a>

                                    }
                                    else
                                    {
                                        <a asp-controller="CarBrowse" asp-action="Details" asp-route-id="@car.Id" class="btn btn-outline-primary btn-sm">Detaylar</a>
                                    }
                                    
                                    
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="alert alert-warning text-center">Gösterilecek araç bulunamadı.</div>
        }
    </div>
</div>
