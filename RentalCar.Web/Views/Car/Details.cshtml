@using RentalCar.Domain.Entities
@using RentalCar.Domain.Extensions
@model RentalCar.ViewModels.CarDetailsViewModel

@{
    ViewData["Title"] = $"{Model.Car.CatalogBrand ?? Model.Car.Brand} {Model.Car.Model}";
    var car = Model.Car;
    string ShowOrDash(string? s) => string.IsNullOrWhiteSpace(s) ? "—" : s!;
    string MoneyOrDash(decimal? v) => (v.HasValue && v.Value > 0) ? $"{v.Value:N0} TL" : "—";
    var hasPredict = car.PredictedPriceMid != null && car.PredictedPriceMid > 0;
    var urls = car.ImageUrls
        .Where(x => !string.IsNullOrWhiteSpace(x))
        .Select(x => x.Trim())
        .ToList();
    if (urls.Count == 0)
        urls = new List<string> { "https://via.placeholder.com/1200x675?text=Arac+Gorseli" };

    string ImgUrl(string img)
    {
        if (string.IsNullOrWhiteSpace(img)) return "https://via.placeholder.com/640x360?text=Arac";
        var t = img.Trim();
        return t.StartsWith("http", StringComparison.OrdinalIgnoreCase) ? t : Url.Content($"~/Images/Upload/{t}")!;
    }

    string DamageSummary()
    {
        var cond = car.VehicleCondition.GetDisplayName();
        if (car.HasAccidentRecord == 1) return $"{cond} · Hasar kaydı bildirilmiş";
        if (car.HasAccidentRecord == 0) return $"{cond} · Hasar kaydı yok (ilan verisi)";
        return cond;
    }

    string FuelUse()
    {
        if (car.FuelConsumptionLPer100Km is double d && d > 0)
            return $"{d:N1} L / 100 km";
        return "—";
    }

    var mailTo = Model.Seller?.Email;
    var mailSubject = Uri.EscapeDataString($"RentalCar ilan #{car.Id} — {car.CatalogBrand ?? car.Brand} {car.Model}");
    var mailBody = Uri.EscapeDataString($"Merhaba,\n\n#{car.Id} numaralı ilan hakkında bilgi almak istiyorum.\n");
    var seller = Model.Seller;
}

<div class="container my-4 my-lg-5 car-detail-page">
    <div class="row g-4 align-items-start">
        @* ——— Galeri ——— *@
        <div class="col-lg-5 order-1">
            <div class="car-detail-gallery card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="ratio ratio-16x9 bg-dark">
                    <img id="car-detail-main-img"
                         src="@ImgUrl(urls[0])"
                         alt="@ShowOrDash(car.CatalogBrand) @ShowOrDash(car.Model)"
                         class="w-100 h-100 object-fit-cover" />
                </div>
                <div class="car-detail-thumbs p-2 p-md-3 d-flex gap-2 flex-nowrap overflow-auto">
                    @{ var ti = 0; }
                    @foreach (var img in urls)
                    {
                        var isFirst = ti == 0;
                        <button type="button"
                                class="car-detail-thumb btn p-0 border-0 rounded-3 overflow-hidden flex-shrink-0 @(isFirst ? "is-active" : "")"
                                data-car-detail-thumb
                                data-full-src="@ImgUrl(img)"
                                aria-label="Görsel @(ti + 1)">
                            <img src="@ImgUrl(img)" alt="" class="thumb-img" width="112" height="72" loading="lazy" />
                        </button>
                        ti++;
                    }
                </div>
            </div>
        </div>

        @* ——— Özellikler & CTA ——— *@
        <div class="col-lg-4 order-2">
            <div class="card border-0 shadow-lg rounded-4 car-detail-spec-card">
                <div class="card-body p-4">
                    <div class="d-flex flex-wrap align-items-start justify-content-between gap-2 mb-2">
                        <h1 class="h4 fw-bold text-white mb-0">@ShowOrDash(car.CatalogBrand) @ShowOrDash(car.Model)</h1>
                        <span class="badge @(Model.ReliabilityLabel == "High" ? "bg-success" : Model.ReliabilityLabel == "Medium" ? "bg-warning text-dark" : "bg-danger") align-self-center">
                            @Model.ReliabilityTrustLevelTr · @Model.ReliabilityScore / 100
                        </span>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(Model.ReliabilityExplanation))
                    {
                        <p class="car-detail-muted-note small mb-2">@Model.ReliabilityExplanation</p>
                    }
                    @if (User.IsInRole("Admin") && Model.ReliabilityFactors is { Count: > 0 } relFactors)
                    {
                        <details class="small mb-3">
                            <summary class="car-detail-muted-note" style="cursor: pointer;">Güven skoru bileşenleri (admin)</summary>
                            <table class="table table-sm table-dark mb-0 mt-2 align-middle">
                                <thead>
                                    <tr><th>Bileşen</th><th class="text-end">Ağırlık</th><th class="text-end">Alt skor</th><th class="text-end">Katkı</th></tr>
                                </thead>
                                <tbody>
                                    @foreach (var f in relFactors)
                                    {
                                        <tr>
                                            <td>
                                                @f.DisplayName
                                                @if (!string.IsNullOrWhiteSpace(f.Note))
                                                {
                                                    <div class="text-muted" style="font-size: 0.72rem;">@f.Note</div>
                                                }
                                            </td>
                                            <td class="text-end">@f.Weight.ToString("0.##")</td>
                                            <td class="text-end">@f.Subscore.ToString("0.#")</td>
                                            <td class="text-end">@f.WeightedContribution.ToString("0.##")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </details>
                    }
                    <p class="car-detail-muted-note small mb-3">@ShowOrDash(car.City) · @car.SellerType.GetDisplayName()</p>

                    <div class="car-detail-price mb-4">@MoneyOrDash(car.ListedPrice)</div>

                    <div class="row g-2 g-md-3 car-detail-spec-grid small">
                        <div class="col-6"><div class="spec-tile"><span class="spec-label">Yıl</span><span class="spec-value">@(car.ModelYear?.ToString() ?? "—")</span></div></div>
                        <div class="col-6"><div class="spec-tile"><span class="spec-label">Kilometre</span><span class="spec-value">@(car.OdometerKm?.ToString("N0") ?? "—") km</span></div></div>
                        <div class="col-6"><div class="spec-tile"><span class="spec-label">Vites</span><span class="spec-value">@car.Transmission.GetDisplayName()</span></div></div>
                        <div class="col-6"><div class="spec-tile"><span class="spec-label">Yakıt</span><span class="spec-value">@car.FuelType.GetDisplayName()</span></div></div>
                        <div class="col-6"><div class="spec-tile"><span class="spec-label">Kasa tipi</span><span class="spec-value">@car.BodyType.GetDisplayName()</span></div></div>
                        <div class="col-6"><div class="spec-tile"><span class="spec-label">Renk</span><span class="spec-value">@ShowOrDash(car.Color)</span></div></div>
                        <div class="col-6"><div class="spec-tile"><span class="spec-label">Motor hacmi</span><span class="spec-value">@(car.EngineDisplacementLiters?.ToString() ?? "—") L</span></div></div>
                        <div class="col-6"><div class="spec-tile"><span class="spec-label">Motor gücü</span><span class="spec-value">@(car.EnginePowerHp?.ToString() ?? "—") bg</span></div></div>
                        <div class="col-6"><div class="spec-tile"><span class="spec-label">Çekiş</span><span class="spec-value">@car.Drivetrain.GetDisplayName()</span></div></div>
                        <div class="col-6"><div class="spec-tile"><span class="spec-label">Yakıt tüketimi</span><span class="spec-value">@FuelUse()</span></div></div>
                        <div class="col-6"><div class="spec-tile"><span class="spec-label">Yakıt deposu</span><span class="spec-value">@(car.FuelTankLiters?.ToString() ?? "—") L</span></div></div>
                        <div class="col-6"><div class="spec-tile"><span class="spec-label">Hasar durumu</span><span class="spec-value">@DamageSummary()</span></div></div>
                        <div class="col-12"><div class="spec-tile"><span class="spec-label">Boya / değişen</span><span class="spec-value">@ShowOrDash(car.BodyWorkNotes)</span></div></div>
                        <div class="col-6"><div class="spec-tile"><span class="spec-label">Takas</span><span class="spec-value">@(car.TradeInAccepted ? "Uygun" : "Uygun değil")</span></div></div>
                    </div>

                    <div class="d-grid gap-2 mt-4">
                        <a asp-controller="Rental" asp-action="RentCar" asp-route-id="@car.Id" class="btn btn-warning btn-lg fw-semibold">Kirala</a>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <a asp-controller="Purchase" asp-action="Confirm" asp-route-carId="@car.Id" class="btn btn-success btn-lg fw-semibold">Satın al</a>
                        }
                        else
                        {
                            <a asp-controller="Account" asp-action="Index" class="btn btn-outline-success btn-lg fw-semibold">Satın al (giriş gerekli)</a>
                        }
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <form asp-controller="Car" asp-action="ToggleFavorite" method="post" class="m-0">
                                <input type="hidden" name="carId" value="@car.Id" />
                                <button type="submit" class="btn btn-danger-soft w-100 btn-lg">
                                    @(Model.IsFavorite ? "Favoriden çıkar" : "Favorilere ekle")
                                </button>
                            </form>
                        }
                        else
                        {
                            <a asp-controller="Account" asp-action="Index" class="btn btn-outline-danger w-100 btn-lg">Favorilere eklemek için giriş</a>
                        }
                    </div>

                    @if (hasPredict)
                    {
                        <div class="mt-4 p-3 rounded-3 car-detail-ai-price-hint">
                            <div class="small text-uppercase text-muted mb-1">AI fiyat bandı</div>
                            <div class="d-flex justify-content-between small"><span>Tahmin</span><strong>@MoneyOrDash(car.PredictedPriceMid)</strong></div>
                            <div class="d-flex justify-content-between small text-muted"><span>Alt</span><span>@MoneyOrDash(car.PredictedPriceMin)</span></div>
                            <div class="d-flex justify-content-between small text-muted"><span>Üst</span><span>@MoneyOrDash(car.PredictedPriceMax)</span></div>
                        </div>
                    }

                    <div class="mt-4 pt-3 border-top border-secondary border-opacity-25">
                        <div class="small text-muted mb-1">Ortalama puan</div>
                        <div class="fw-semibold">@Model.AverageRating.ToString("N1") / 5 <span class="text-muted fw-normal">(@Model.RatingCount değerlendirme)</span></div>
                    </div>

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <div class="mt-3">
                            <form asp-controller="Car" asp-action="Rate" method="post" class="d-flex flex-wrap align-items-center gap-2">
                                <input type="hidden" name="carId" value="@car.Id" />
                                <select name="score" class="form-select form-select-sm" style="max-width:9rem;">
                                    @for (var i = 1; i <= 5; i++)
                                    {
                                        if (Model.CurrentUserRating == i)
                                        {
                                            <option value="@i" selected>@i yıldız</option>
                                        }
                                        else
                                        {
                                            <option value="@i">@i yıldız</option>
                                        }
                                    }
                                </select>
                                <button type="submit" class="btn btn-outline-primary btn-sm">Puanla</button>
                            </form>
                        </div>
                    }
                </div>
            </div>
        </div>

        @* ——— Satıcı ——— *@
        <div class="col-lg-3 order-3">
            <div class="card border-0 shadow-lg rounded-4 car-detail-seller-card sticky-lg-top">
                <div class="card-body p-4">
                    <h2 class="h6 text-uppercase text-muted mb-3">Satıcı</h2>
                    <div class="d-flex align-items-center gap-3 mb-3">
                        <div class="seller-avatar rounded-circle d-flex align-items-center justify-content-center fw-bold">
                            @(seller?.DisplayName.Length > 0 ? seller.DisplayName[0].ToString().ToUpperInvariant() : "?")
                        </div>
                        <div>
                            <div class="fw-bold text-white">@seller?.DisplayName</div>
                            <div class="small text-muted">@seller?.ProfileTypeLabel</div>
                        </div>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(seller?.PhoneNumber))
                    {
                        <button type="button" class="btn btn-outline-warning w-100 mb-2" id="carDetailShowPhone" data-phone="@seller.PhoneNumber">
                            Telefonu göster
                        </button>
                        <div id="carDetailPhoneReveal" class="alert alert-dark border-secondary py-2 small d-none mb-2" role="status"></div>
                    }
                    else
                    {
                        <div class="small text-muted mb-2">Bu ilan için kayıtlı telefon gösterilmiyor.</div>
                    }

                    @if (!string.IsNullOrWhiteSpace(mailTo))
                    {
                        <a class="btn btn-outline-light w-100 mb-2" href="mailto:@mailTo?subject=@mailSubject&body=@mailBody">Mesaj gönder</a>
                    }
                    else
                    {
                        <button type="button" class="btn btn-outline-secondary w-100 mb-2" disabled title="E-posta kayıtlı değil">Mesaj gönder</button>
                    }

                    @if (!string.IsNullOrWhiteSpace(seller?.UserId))
                    {
                        <a class="btn btn-primary-gradient w-100 mb-2"
                           asp-controller="Car" asp-action="List" asp-route-postedBy="@seller.UserId">
                            Tüm ilanlarını gör @(seller.OtherListingsCount > 0 ? $"({seller.OtherListingsCount})" : "")
                        </a>
                    }
                    else
                    {
                        <a class="btn btn-outline-primary w-100 mb-2"
                           asp-controller="Car" asp-action="List"
                           asp-route-brand="@car.CatalogBrand"
                           asp-route-model="@car.Model">
                            Benzer ilanlara git
                        </a>
                    }

                    <a asp-controller="Car" asp-action="List" class="btn btn-link btn-sm text-decoration-none px-0 text-muted">← Tüm ilanlar</a>
                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-controller="Car" asp-action="Edit" asp-route-id="@car.Id" class="btn btn-outline-info w-100 mt-2">Düzenle (admin)</a>
                    }
                </div>
            </div>
        </div>
    </div>

    @* ——— Benzer araçlar ——— *@
    @if (Model.SimilarCars.Count > 0)
    {
        <section class="mt-5 pt-4 border-top border-secondary border-opacity-25">
            <div class="d-flex align-items-end justify-content-between flex-wrap gap-2 mb-3">
                <h2 class="h4 fw-bold text-white mb-0">Benzer araçlar</h2>
                <span class="small text-muted">Aynı marka / model veya yakın fiyat bandı</span>
            </div>
            <div class="row row-cols-1 row-cols-sm-2 row-cols-xl-4 g-3">
                @foreach (var sc in Model.SimilarCars)
                {
                    var simImg = sc.ImageUrls.FirstOrDefault(x => !string.IsNullOrWhiteSpace(x));
                    <div class="col">
                        <div class="card h-100 listing-card border-0 rounded-4 overflow-hidden shadow-sm car-detail-sim-card">
                            <a asp-action="Details" asp-route-id="@sc.Id" class="ratio ratio-16x9 d-block">
                                <img src="@ImgUrl(simImg ?? "")" alt="" class="w-100 h-100 object-fit-cover" />
                            </a>
                            <div class="card-body p-3 d-flex flex-column">
                                <div class="fw-semibold text-white small mb-1">@(sc.CatalogBrand ?? sc.Brand) @sc.Model</div>
                                <div class="listing-price mb-1">@MoneyOrDash(sc.ListedPrice)</div>
                                <div class="small text-muted mt-auto">
                                    @(sc.ModelYear?.ToString() ?? "—") · @(sc.OdometerKm?.ToString("N0") ?? "—") km
                                </div>
                                <a asp-action="Details" asp-route-id="@sc.Id" class="btn btn-sm btn-outline-primary mt-2">İncele</a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </section>
    }

    @* ——— AI önerileri ——— *@
    @if (Model.ListingInsights != null)
    {
        var ai = Model.ListingInsights;
        <section class="mt-5 pt-4 border-top border-secondary border-opacity-25" id="ai-onerileri">
            <div class="d-flex flex-wrap align-items-center gap-2 mb-3">
                <h2 class="h4 fw-bold text-white mb-0">AI önerileri</h2>
                <span class="badge bg-gradient-ai">@(ai.UsedLlm ? "LLM" : "Kural + özet")</span>
            </div>

            <div class="row g-3 mb-3">
                <div class="col-md-4">
                    <div class="card car-detail-ai-panel h-100 border-0 rounded-4">
                        <div class="card-body p-4">
                            <div class="car-detail-ai-label mb-2">Bu araç alınır mı?</div>
                            <p class="mb-0 car-detail-ai-body">@ShowOrDash(ai.PurchaseVerdict)</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card car-detail-ai-panel h-100 border-0 rounded-4">
                        <div class="card-body p-4">
                            <div class="car-detail-ai-label mb-2">Fiyat analizi</div>
                            <p class="mb-0 car-detail-ai-body">@ShowOrDash(ai.PriceAnalysis)</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card car-detail-ai-panel h-100 border-0 rounded-4">
                        <div class="card-body p-4">
                            <div class="car-detail-ai-label mb-2">Neden bu öneri?</div>
                            <p class="mb-0 car-detail-ai-body">@ShowOrDash(ai.RecommendationRationale)</p>
                        </div>
                    </div>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(ai.SummaryText))
            {
                <p class="car-detail-ai-summary small mb-3">@ai.SummaryText</p>
            }

            <div class="row g-4">
                <div class="col-lg-6">
                    @if (ai.Bullets.Count > 0)
                    {
                        <div class="fw-semibold text-white mb-2">Öne çıkan maddeler</div>
                        <ul class="small car-detail-ai-list ps-3 mb-0">
                            @foreach (var b in ai.Bullets)
                            {
                                <li class="mb-1">@b</li>
                            }
                        </ul>
                    }
                </div>
                <div class="col-lg-6">
                    @if (ai.Alternatives.Count > 0)
                    {
                        <div class="fw-semibold text-white mb-2">Alternatif düşünceler</div>
                        <ul class="small car-detail-ai-list ps-3 mb-0">
                            @foreach (var a in ai.Alternatives)
                            {
                                <li class="mb-1">@a</li>
                            }
                        </ul>
                    }
                </div>
            </div>
        </section>
    }

    @* ——— Açıklama & yorumlar ——— *@
    <section class="mt-5 pt-4 border-top border-secondary border-opacity-25">
        <div class="row g-4">
            <div class="col-lg-7">
                <h3 class="h5 fw-bold text-white mb-3">İlan açıklaması</h3>
                <div class="car-detail-description-wrap">
                    @if (string.IsNullOrWhiteSpace(car.ShortDescription) && string.IsNullOrWhiteSpace(car.FullDescription))
                    {
                        <p class="car-detail-empty-note mb-0">Bu ilan için satıcı açıklaması girilmemiş. Detaylı bilgi için satıcıyla iletişime geçebilirsiniz.</p>
                    }
                    else
                    {
                        @if (!string.IsNullOrWhiteSpace(car.ShortDescription))
                        {
                            <p class="car-detail-description-lead mb-3">@car.ShortDescription</p>
                        }
                        @if (!string.IsNullOrWhiteSpace(car.FullDescription))
                        {
                            <div class="car-detail-description-body" style="white-space: pre-wrap;">@car.FullDescription</div>
                        }
                    }
                </div>
            </div>
            <div class="col-lg-5">
                <h3 class="h5 fw-bold text-white mb-3">Yorumlar</h3>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <form asp-controller="Car" asp-action="AddComment" method="post" class="mb-3">
                        <input type="hidden" name="carId" value="@car.Id" />
                        <div class="input-group">
                            <input type="text" name="content" class="form-control" placeholder="Yorumunuzu yazın..." required maxlength="1500" />
                            <button type="submit" class="btn btn-primary-gradient">Gönder</button>
                        </div>
                    </form>
                }
                @if (Model.Comments.Any())
                {
                    foreach (var comment in Model.Comments)
                    {
                        var split = comment.Content.Split('|', 2);
                        var commenter = split.Length == 2 ? split[0] : "Kullanıcı";
                        var body = split.Length == 2 ? split[1] : comment.Content;
                        <div class="border border-secondary border-opacity-25 rounded-3 p-3 mb-2 bg-black bg-opacity-25">
                            <div class="small fw-semibold text-white">@commenter</div>
                            <div class="car-detail-comment-body small">@body</div>
                        </div>
                    }
                }
                else
                {
                    <div class="car-detail-muted-note small">Henüz yorum yok.</div>
                }
            </div>
        </div>
    </section>

    @if (Model.RecommendedCars.Any())
    {
        <section class="mt-5 pt-4 border-top border-secondary border-opacity-25">
            <h3 class="h5 fw-bold text-white mb-3">Favorilerinize göre</h3>
            <div class="row g-3">
                @foreach (var rec in Model.RecommendedCars)
                {
                    <div class="col-md-6 col-xl-4">
                        <div class="card border-0 rounded-4 car-detail-rec-card h-100 p-3">
                            <div class="fw-semibold text-white">@(rec.CatalogBrand ?? rec.Brand) @rec.Model</div>
                            <div class="small text-muted">@ShowOrDash(rec.City) · @rec.FuelType.GetDisplayName()</div>
                            <div class="listing-price mt-2">@MoneyOrDash(rec.ListedPrice)</div>
                            <a asp-action="Details" asp-route-id="@rec.Id" class="btn btn-sm btn-outline-primary mt-2">Detay</a>
                        </div>
                    </div>
                }
            </div>
        </section>
    }
</div>

@section Scripts {
    <script>
        (function () {
            var main = document.getElementById('car-detail-main-img');
            document.querySelectorAll('[data-car-detail-thumb]').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    var src = this.getAttribute('data-full-src');
                    if (main && src) {
                        main.src = src;
                        document.querySelectorAll('[data-car-detail-thumb]').forEach(function (b) { b.classList.remove('is-active'); });
                        this.classList.add('is-active');
                    }
                });
            });

            var phoneBtn = document.getElementById('carDetailShowPhone');
            var phoneBox = document.getElementById('carDetailPhoneReveal');
            if (phoneBtn && phoneBox) {
                phoneBtn.addEventListener('click', function () {
                    var p = phoneBtn.getAttribute('data-phone') || '';
                    phoneBox.textContent = p ? ('Telefon: ' + p) : 'Numara bulunamadı.';
                    phoneBox.classList.remove('d-none');
                    phoneBtn.disabled = true;
                });
            }
        })();
    </script>
}
