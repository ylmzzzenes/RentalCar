@using RentalCar.Data.Models
@model RentalCar.ViewModels.CarDetailsViewModel

@{
    var car = Model.Car;
    string ShowOrDash(string? s) => string.IsNullOrWhiteSpace(s) ? "-" : s;
    string MoneyOrDash(decimal? v) => (v.HasValue && v.Value > 0) ? $"{v.Value:N0} TL" : "-";
    var hasPredict = car.fiyat_tahmin != null && car.fiyat_tahmin > 0;
    var urls = (car.ImageUrls ?? "")
        .Split(',', StringSplitOptions.RemoveEmptyEntries)
        .Select(x => x.Trim())
        .Where(x => !string.IsNullOrWhiteSpace(x))
        .ToList();
}

<div class="container my-5">
    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow rounded-4 p-3 mb-4">
                @if (urls.Any())
                {
                    <img src="~/Images/Upload/@urls.First()"
                         class="img-fluid rounded-3 mb-3"
                         alt="@ShowOrDash(car.marka) @car.model"
                         style="width:100%; max-height:420px; object-fit:cover;" />
                }
                else
                {
                    <img src="https://via.placeholder.com/1024x576?text=Arac+Gorseli"
                         class="img-fluid rounded-3 mb-3"
                         style="width:100%; max-height:420px; object-fit:cover;" />
                }
                <div class="d-flex flex-wrap gap-2">
                    @foreach (var img in urls.Skip(1))
                    {
                        <img src="~/Images/Upload/@img" class="rounded-3" style="height:70px; width:110px; object-fit:cover;" />
                    }
                </div>
            </div>

            <div class="card border-0 shadow rounded-4 p-4">
                <h4 class="fw-bold text-dark mb-2">@ShowOrDash(car.marka) @ShowOrDash(car.model)</h4>
                <div class="text-muted mb-3">Ortalama Puan: <strong>@Model.AverageRating.ToString("N1")</strong> / 5 (@Model.RatingCount degerlendirme)</div>
                <div class="row small">
                    <div class="col-6 mb-2"><strong>Yil:</strong> @(car.yil?.Year)</div>
                    <div class="col-6 mb-2"><strong>Kilometre:</strong> @(car.kilometre?.ToString("N0") ?? "-") km</div>
                    <div class="col-6 mb-2"><strong>Yakit:</strong> @car.yakitTuru</div>
                    <div class="col-6 mb-2"><strong>Vites:</strong> @car.vites</div>
                    <div class="col-6 mb-2"><strong>Kasa:</strong> @car.BodyType</div>
                    <div class="col-6 mb-2"><strong>Renk:</strong> @ShowOrDash(car.renk)</div>
                    <div class="col-6 mb-2"><strong>Motor:</strong> @(car.motorHacmi?.ToString() ?? "-") lt / @(car.motorGuc_hp?.ToString() ?? "-") hp</div>
                    <div class="col-6 mb-2"><strong>Sehir:</strong> @ShowOrDash(car.sehir)</div>
                </div>
                <div class="mt-3">
                    <div class="listing-price fs-4">@MoneyOrDash(car.fiyat)</div>
                    <p class="text-muted mt-2">@ShowOrDash(car.aciklama_kisa)</p>
                    <p>@ShowOrDash(car.aciklama)</p>
                </div>

                @if (User.Identity?.IsAuthenticated == true)
                {
                    <hr />
                    <div class="d-flex flex-wrap gap-2">
                        <form asp-controller="Car" asp-action="ToggleFavorite" method="post">
                            <input type="hidden" name="carId" value="@car.Id" />
                            <button class="btn @(Model.IsFavorite ? "btn-danger" : "btn-outline-danger") btn-sm">
                                @(Model.IsFavorite ? "Favoriden Cikar" : "Favorilere Ekle")
                            </button>
                        </form>

                        <form asp-controller="Car" asp-action="Rate" method="post" class="d-flex align-items-center gap-2">
                            <input type="hidden" name="carId" value="@car.Id" />
                            <select name="score" class="form-select form-select-sm" style="width:140px;">
                                @for (var i = 1; i <= 5; i++)
                                {
                                    <option value="@i" selected="@(Model.CurrentUserRating == i)">@i Yildiz</option>
                                }
                            </select>
                            <button class="btn btn-outline-primary btn-sm">Puanla</button>
                        </form>
                    </div>

                    <form asp-controller="Car" asp-action="AddComment" method="post" class="mt-3">
                        <input type="hidden" name="carId" value="@car.Id" />
                        <div class="input-group">
                            <input type="text" name="content" class="form-control" placeholder="Yorumunuzu yazin..." required maxlength="1500" />
                            <button class="btn btn-primary-gradient">Yorum Ekle</button>
                        </div>
                    </form>
                }

                <div class="mt-4">
                    <h5 class="mb-3">Yorumlar</h5>
                    @if (Model.Comments.Any())
                    {
                        foreach (var comment in Model.Comments)
                        {
                            var split = comment.Content.Split('|', 2);
                            var commenter = split.Length == 2 ? split[0] : "Kullanici";
                            var body = split.Length == 2 ? split[1] : comment.Content;
                            <div class="border rounded-3 p-3 mb-2 bg-light">
                                <div class="small fw-semibold text-dark">@commenter</div>
                                <div class="text-muted small">@body</div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-muted small">Henuz yorum yok.</div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow rounded-4 p-4 sticky-top" style="top:95px;">
                <h5 class="fw-bold mb-3">@ShowOrDash(car.marka) @ShowOrDash(car.model)</h5>
                <p class="text-muted mb-2">Guncel Fiyat</p>
                <div class="listing-price fs-3 mb-3">@MoneyOrDash(car.fiyat)</div>
                <div class="d-grid gap-2">
                    <a asp-controller="Rental" asp-action="RentCar" asp-route-id="@car.Id" class="btn btn-warning">Kirala</a>
                    <a asp-controller="Car" asp-action="List" class="btn btn-outline-secondary">Ilanlara Don</a>
                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-controller="Car" asp-action="Edit" asp-route-id="@car.Id" class="btn btn-outline-primary">Duzenle</a>
                    }
                </div>
                @if (hasPredict)
                {
                    <hr />
                    <div class="small">
                        <div class="d-flex justify-content-between"><span>Tahmin</span><strong>@MoneyOrDash(car.fiyat_tahmin)</strong></div>
                        <div class="d-flex justify-content-between"><span>Alt</span><span>@MoneyOrDash(car.fiyat_min)</span></div>
                        <div class="d-flex justify-content-between"><span>Ust</span><span>@MoneyOrDash(car.fiyat_max)</span></div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
