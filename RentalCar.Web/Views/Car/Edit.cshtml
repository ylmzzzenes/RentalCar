@model RentalCar.Domain.Entities.Car

@{
    ViewData["Title"] = "Ilan Guncelle";
}

<div class="auth-card" style="max-width:840px;">
    <h3 class="auth-title mb-3">@ViewData["Title"]</h3>
    <form asp-action="Edit" method="post">
        <input type="hidden" asp-for="Id" />
        @for (var i = 0; i < Model.ImageUrls.Count; i++)
        {
            <input type="hidden" asp-for="ImageUrls[i]" />
        }
        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="Brand" class="form-label">Marka</label>
                <input asp-for="Brand" class="form-control" />
            </div>
            <div class="col-md-6">
                <label asp-for="Model" class="form-label">Model</label>
                <input asp-for="Model" class="form-control" />
            </div>
            <div class="col-md-6">
                <label asp-for="ModelYear" class="form-label">Yil</label>
                <input asp-for="ModelYear" type="number" min="1950" max="2100" class="form-control" />
            </div>
            <div class="col-md-6">
                <label asp-for="Color" class="form-label">Renk</label>
                <input asp-for="Color" class="form-control" />
            </div>
            <div class="col-md-6">
                <label asp-for="Plate" class="form-label">Plaka</label>
                <input asp-for="Plate" class="form-control" />
            </div>
            <div class="col-md-6">
                <label asp-for="ListedPrice" class="form-label">Fiyat</label>
                <input asp-for="ListedPrice" class="form-control" />
            </div>
        </div>
        <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn btn-primary-gradient">Guncelle</button>
            <a asp-action="List" class="btn btn-outline-light">Iptal</a>
        </div>
    </form>
</div>
