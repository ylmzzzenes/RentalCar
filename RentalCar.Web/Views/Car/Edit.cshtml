@using RentalCar.Data.Enums 
@model RentalCar.Data.Models.Car


@{
    ViewData["Title"] = "Ilan Guncelle";
}

<div class="auth-card" style="max-width:840px;">
    <h3 class="auth-title mb-3">@ViewData["Title"]</h3>
    <form asp-action="Edit" method="post">
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="ImageUrls" />
        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="Brand" class="form-label">Marka</label>
                <input asp-for="Brand" class="form-control" />
            </div>
            <div class="col-md-6">
                <label asp-for="model" class="form-label">Model</label>
                <input asp-for="model" class="form-control" />
            </div>
            <div class="col-md-6">
                <label asp-for="yil" class="form-label">Yil</label>
                <input asp-for="yil" type="date" class="form-control" />
            </div>
            <div class="col-md-6">
                <label asp-for="renk" class="form-label">Renk</label>
                <input asp-for="renk" class="form-control" />
            </div>
            <div class="col-md-6">
                <label asp-for="Plate" class="form-label">Plaka</label>
                <input asp-for="Plate" class="form-control" />
            </div>
            <div class="col-md-6">
                <label asp-for="fiyat" class="form-label">Fiyat</label>
                <input asp-for="fiyat" class="form-control" />
            </div>
        </div>
        <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn btn-primary-gradient">Guncelle</button>
            <a asp-action="List" class="btn btn-outline-light">Iptal</a>
        </div>
    </form>
</div>
