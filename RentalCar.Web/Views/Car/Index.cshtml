@using RentalCar.Domain.Enums
@using VehicleDriveType = RentalCar.Domain.Enums.DriveType
@model RentalCar.Web.Models.Requests.CreateCar

@{
    ViewData["Title"] = "Araç Ekle";
}

<form asp-controller="Car" asp-action="Create" method="post" enctype="multipart/form-data">
    <div asp-validation-summary="All" class="text-danger"></div>
    <div class="col-md-12">
        <label asp-for="Model" class="form-label fw-semibold">Model </label>
        <input asp-for="Model" class="form-control form-control-sm shadow-sm"
               placeholder="Örn: Ford Fiesta 1.0 EcoBoost ST-Line" />
        <span asp-validation-for="Model" class="text-danger small"></span>
    </div>

    <div class="col-md-4">
        <label asp-for="CatalogBrand" class="form-label fw-semibold">Marka</label>
        <input asp-for="CatalogBrand" class="form-control form-control-sm shadow-sm" placeholder="Ford" />
    </div>

    <div class="col-md-4">
        <label asp-for="CatalogModelName" class="form-label fw-semibold">Model Adı </label>
        <input asp-for="CatalogModelName" class="form-control form-control-sm shadow-sm" placeholder="Fiesta" />
    </div>

    <div class="col-md-4">
        <label asp-for="TrimPackage" class="form-label fw-semibold">Paket </label>
        <input asp-for="TrimPackage" class="form-control form-control-sm shadow-sm" placeholder="ST-Line" />
    </div>

    <div class="col-md-4 mb-3">
        <label asp-for="EngineCode" class="form-label fw-semibold">Motor Kodu </label>
        <input asp-for="EngineCode" class="form-control form-control-sm shadow-sm" placeholder="EcoBoost / TDI / TSI" />
    </div>

    <select name="Drivetrain" class="form-select form-select-sm mb-3 shadow-sm">
        <option value="">Çekiş</option>
        @foreach (var d in Enum.GetValues(typeof(VehicleDriveType)))
        {
            <option value="@d">@d</option>
        }
    </select>

    <div class="col-md-4">
        <label asp-for="TransmissionCode" class="form-label fw-semibold">Şanzıman Kodu </label>
        <input asp-for="TransmissionCode" class="form-control form-control-sm shadow-sm" placeholder="DSG / DCT / CVT / MT" />
    </div>

    <div class="col-md-4">
        <label asp-for="ModelYear" class="form-label fw-semibold">Yıl </label>
        <input asp-for="ModelYear" type="number" min="1950" max="2100" class="form-control form-control-sm shadow-sm" placeholder="2018" />
    </div>

    <div class="col-md-6 mb-3">
        <label asp-for="ListedPrice" class="form-label fw-semibold">Fiyat (TL)</label>
        <input asp-for="ListedPrice" type="number" class="form-control form-control-sm shadow-sm" placeholder="980000" />
    </div>

    <select name="Transmission" class="form-select form-select-sm mb-3 shadow-sm">
        <option value="">Vites</option>
        @foreach (var g in Enum.GetValues(typeof(Gear)))
        {
            <option value="@g">@g</option>
        }
    </select>

    <div class="col-md-3 mb-3">
        <label asp-for="OdometerKm" class="form-label fw-semibold">Kilometre</label>
        <input asp-for="OdometerKm" type="number" class="form-control form-control-sm shadow-sm" placeholder="11000" />
    </div>

    <select name="FuelType" class="form-select form-select-sm mb-3 shadow-sm">
        <option value="">Yakit Türü</option>
        @foreach (var y in Enum.GetValues(typeof(FuelType)))
        {
            <option value="@y">@y</option>
        }
    </select>

    <div class="col-md-3">
        <label asp-for="TaxAmount" class="form-label fw-semibold">Vergi</label>
        <input asp-for="TaxAmount" type="number" class="form-control form-control-sm shadow-sm" placeholder="145" />
    </div>

    <div class="col-md-3">
        <label asp-for="FuelConsumptionLPer100Km" class="form-label fw-semibold">Lt/100km</label>
        <input asp-for="FuelConsumptionLPer100Km" type="number" step="0.1" class="form-control form-control-sm shadow-sm" placeholder="4.5" />
    </div>

    <div class="col-md-3">
        <label asp-for="EngineDisplacementLiters" class="form-label fw-semibold">Motor Hacmi</label>
        <input asp-for="EngineDisplacementLiters" type="number" step="0.1" class="form-control form-control-sm shadow-sm" placeholder="1.0" />
    </div>
    <div class="col-md-3 mb-3">
        <label asp-for="Color" class="form-label fw-semibold">Renk</label>
        <input asp-for="Color" class="form-control form-control-sm shadow-sm" placeholder="Kırmızı/Siyah/Mavi/Beyaz" />
    </div>
    <div class="col-md-3 mb-3">
        <label asp-for="City" class="form-label fw-semibold">Şehir</label>
        <input asp-for="City" class="form-control form-control-sm shadow-sm" placeholder="İstanbul" />
    </div>
    <div class="col-md-3 mb-3">
        <label asp-for="BodyStyleLabel" class="form-label fw-semibold">Kasa Tipi</label>
        <input asp-for="BodyStyleLabel" class="form-control form-control-sm shadow-sm" placeholder="SUV" />
    </div>
    <div class="col-md-3 mb-3">
        <label asp-for="TrimLevelLabel" class="form-label fw-semibold">Donanım Seviyesi</label>
        <input asp-for="TrimLevelLabel" class="form-control form-control-sm shadow-sm" placeholder="Orta" />
    </div>

    <div class="col-md-3 mb-3">
        <label asp-for="EnginePowerHp" class="form-label fw-semibold">Motor Gücü</label>
        <input asp-for="EnginePowerHp" class="form-control form-control-sm shadow-sm" placeholder="90" />
    </div>

    <div class="col-md-3 mb-3">
        <label asp-for="TorqueNm" class="form-label fw-semibold">Tork</label>
        <input asp-for="TorqueNm" class="form-control form-control-sm shadow-sm" placeholder="300" />
    </div>

    <div class="col-md-3 mb-3">
        <label asp-for="HasAccidentRecord" class="form-label fw-semibold">Hasar Kaydı</label>
        <input asp-for="HasAccidentRecord" class="form-control form-control-sm shadow-sm" placeholder="1/0" />
    </div>
    <div class="col-md-3 mb-3">
        <label asp-for="BodyWorkNotes" class="form-label fw-semibold">Değişen-Boyanan</label>
        <input asp-for="BodyWorkNotes" class="form-control form-control-sm shadow-sm" placeholder="3-4 parça" />
    </div>
    <div class="col-md-3 mb-3">
        <label asp-for="PreviousOwnerCount" class="form-label fw-semibold">Sahip Sayısı</label>
        <input asp-for="PreviousOwnerCount" class="form-control form-control-sm shadow-sm" placeholder="2" />
    </div>
    <div class="col-md-3 mb-3">
        <label asp-for="HasServiceHistory" class="form-label fw-semibold">Servis Geçmişi</label>
        <input asp-for="HasServiceHistory" class="form-control form-control-sm shadow-sm" placeholder="1" />
    </div>

    @await Component.InvokeAsync("EnumSelector")

    <div class="col-md-12 mb-3">
        <label asp-for="PhotoUploads" class="form-label fw-semibold">Araç Fotoğrafları</label>
        <input asp-for="PhotoUploads"
               type="file"
               multiple
               accept="image/*"
               class="form-control form-control-sm shadow-sm" />
        <span asp-validation-for="PhotoUploads" class="text-danger small"></span>
        <div class="form-text">Birden fazla fotoğraf seçebilirsin (JPG/PNG).</div>
    </div>

    <div class="col-md-3 mb-3">
        <button type="submit" class="btn btn-primary">Kaydet</button>
    </div>
</form>
