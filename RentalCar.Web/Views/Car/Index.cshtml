@using RentalCar.Domain.Enums
@using VehicleDriveType = RentalCar.Domain.Enums.DriveType
@model RentalCar.Web.Models.Requests.CreateCar

@{
    ViewData["Title"] = "Araç Ekle";
}

@if (TempData["CreateSuccess"] is string success)
{
    <div class="alert alert-success">@success</div>
}

@if (TempData["CreateAiSummary"] is string aiSummary)
{
    <div class="alert alert-info">@aiSummary</div>
}

<div class="container py-3">
    <h3 class="mb-3">Yeni Araç İlanı</h3>
    <form id="createCarForm" asp-controller="Car" asp-action="Create" method="post" enctype="multipart/form-data" class="row g-3">
        <div asp-validation-summary="All" class="alert validation-errors-alert border-0 shadow-sm" role="alert"></div>

        <div class="col-md-4">
            <label asp-for="CatalogBrand" class="form-label fw-semibold">Marka</label>
            <input asp-for="CatalogBrand" class="form-control form-control-sm shadow-sm" placeholder="Örn. BMW" />
        </div>

        <div class="col-md-4">
            <label asp-for="Series" class="form-label fw-semibold">Seri</label>
            <input asp-for="Series" class="form-control form-control-sm shadow-sm" placeholder="Örn. 3 Serisi" />
        </div>

        <div class="col-md-4">
            <label asp-for="Model" class="form-label fw-semibold">Model</label>
            <input asp-for="Model" class="form-control form-control-sm shadow-sm" placeholder="Örn. 320i M Sport" />
            <span asp-validation-for="Model" class="text-danger small"></span>
        </div>

        <div class="col-md-4">
            <label asp-for="ModelYear" class="form-label fw-semibold">Yıl</label>
            <input asp-for="ModelYear" type="number" min="1950" max="2100" class="form-control form-control-sm shadow-sm" placeholder="2018" />
        </div>

        <div class="col-md-4">
            <label asp-for="OdometerKm" class="form-label fw-semibold">Kilometre</label>
            <input asp-for="OdometerKm" type="number" min="0" class="form-control form-control-sm shadow-sm" placeholder="45000" />
        </div>

        <div class="col-md-4">
            <label asp-for="ListedPrice" class="form-label fw-semibold">Fiyat (TL)</label>
            <input asp-for="ListedPrice" type="number" min="0" step="1" class="form-control form-control-sm shadow-sm" placeholder="1250000" />
        </div>

        <div class="col-md-4">
            <label asp-for="Transmission" class="form-label fw-semibold">Vites tipi</label>
            <select asp-for="Transmission" class="form-select form-select-sm shadow-sm" asp-items="FlagsEnumSelectList.For<Gear>()"></select>
        </div>

        <div class="col-md-4">
            <label asp-for="FuelType" class="form-label fw-semibold">Yakıt tipi</label>
            <select asp-for="FuelType" class="form-select form-select-sm shadow-sm" asp-items="FlagsEnumSelectList.For<FuelType>()"></select>
        </div>

        <div class="col-md-4">
            <label asp-for="EngineDisplacementLiters" class="form-label fw-semibold">Motor hacmi (L)</label>
            <input asp-for="EngineDisplacementLiters" type="number" step="0.1" min="0" class="form-control form-control-sm shadow-sm" placeholder="2.0" />
        </div>

        <div class="col-md-4">
            <label asp-for="EnginePowerHp" class="form-label fw-semibold">Motor gücü (bg)</label>
            <input asp-for="EnginePowerHp" type="number" min="0" class="form-control form-control-sm shadow-sm" placeholder="184" />
        </div>

        <div class="col-md-4">
            <label asp-for="Drivetrain" class="form-label fw-semibold">Çekiş</label>
            <select asp-for="Drivetrain" class="form-select form-select-sm shadow-sm" asp-items="FlagsEnumSelectList.For<VehicleDriveType>()"></select>
        </div>

        <div class="col-md-4">
            <label asp-for="FuelTankLiters" class="form-label fw-semibold">Yakıt deposu (L)</label>
            <input asp-for="FuelTankLiters" type="number" min="0" class="form-control form-control-sm shadow-sm" placeholder="59" />
        </div>

        <div class="col-md-4">
            <label asp-for="ListingBodyType" class="form-label fw-semibold">Kasa tipi</label>
            <select asp-for="ListingBodyType" class="form-select form-select-sm shadow-sm" asp-items="FlagsEnumSelectList.For<BodyType>()"></select>
        </div>

        <div class="col-md-4">
            <label asp-for="Color" class="form-label fw-semibold">Renk</label>
            <input asp-for="Color" class="form-control form-control-sm shadow-sm" placeholder="Örn. Alpine Beyazı" />
        </div>

        <div class="col-md-4">
            <label asp-for="VehicleCondition" class="form-label fw-semibold">Araç durumu</label>
            <select asp-for="VehicleCondition" class="form-select form-select-sm shadow-sm" asp-items="Html.GetEnumSelectList<VehicleCondition>()"></select>
        </div>

        <div class="col-md-4">
            <label asp-for="BodyWorkNotes" class="form-label fw-semibold">Boya — değişen durumu</label>
            <input asp-for="BodyWorkNotes" class="form-control form-control-sm shadow-sm" placeholder="Örn. Sol arka çamurluk boyalı" />
        </div>

        <div class="col-md-4 d-flex align-items-end">
            <div class="form-check">
                <input asp-for="TradeInAccepted" class="form-check-input" />
                <label asp-for="TradeInAccepted" class="form-check-label fw-semibold">Takasa uygun</label>
            </div>
        </div>

        <div class="col-md-4">
            <label asp-for="SellerType" class="form-label fw-semibold">Kimden</label>
            <select asp-for="SellerType" class="form-select form-select-sm shadow-sm" asp-items="Html.GetEnumSelectList<ListingSellerType>()"></select>
        </div>

        <div class="col-md-12">
            <label asp-for="PhotoUploads" class="form-label fw-semibold">Araç fotoğrafları</label>
            <input asp-for="PhotoUploads"
                   type="file"
                   multiple
                   accept="image/*"
                   class="form-control form-control-sm shadow-sm" />
            <span asp-validation-for="PhotoUploads" class="text-danger small"></span>
            <div class="form-text">JPG/PNG/WEBP dosyaları yüklenebilir.</div>
        </div>

        <div class="col-md-12 d-flex gap-2">
            <button id="createButton" type="submit" class="btn btn-primary">
                <span id="createSpinner" class="spinner-border spinner-border-sm me-2 d-none" role="status"></span>
                Kaydet ve AI analizi üret
            </button>
            <a asp-controller="Car" asp-action="List" class="btn btn-outline-secondary">Listeye dön</a>
        </div>
    </form>
</div>

<script>
    document.getElementById("createCarForm")?.addEventListener("submit", function () {
        const spinner = document.getElementById("createSpinner");
        const button = document.getElementById("createButton");
        spinner?.classList.remove("d-none");
        if (button) button.setAttribute("disabled", "disabled");
    });
</script>
