<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - RentalCar</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="app-shell">
        <nav class="navbar navbar-expand-lg app-navbar">
            <div class="container">
                <a class="navbar-brand app-brand" asp-controller="Home" asp-action="Index">RentalCar</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarNav">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <ul class="navbar-nav me-auto gap-lg-1">
                            <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Anasayfa</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Car" asp-action="List">Araçlar</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Favorites" asp-action="Index">Favoriler</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Ratings" asp-action="Index">Puanlamalar</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Car" asp-action="Index">Araç Ekle</a></li>
                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item"><a class="nav-link" asp-controller="Admin" asp-action="Dashboard">Admin Paneli</a></li>
                            }
                            <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="About">Hakkımızda</a></li>
                        </ul>

                        <form asp-controller="Car" asp-action="List" method="get" class="d-flex me-lg-3 mt-3 mt-lg-0" role="search">
                            <input class="form-control form-control-sm me-2" type="search" name="searchString" placeholder="Ara..." />
                            <button class="btn btn-outline-light btn-sm" type="submit">Bul</button>
                        </form>

                        <div class="d-flex align-items-center gap-2 mt-3 mt-lg-0">
                            <span class="user-chip">Merhaba, @User.Identity?.Name</span>
                            <a asp-controller="Profile" asp-action="Index" class="btn btn-sm btn-outline-light">Profil</a>
                            <a asp-controller="Account" asp-action="Logout" class="btn btn-sm btn-danger-soft">Cikis</a>
                        </div>
                    }
                    else
                    {
                        <ul class="navbar-nav me-auto mt-3 mt-lg-0">
                            <li class="nav-item me-2">
                                <a class="nav-link" asp-controller="Home" asp-action="Index">Anasayfa</a>
                            </li>
                            <li class="nav-item me-2">
                                <a class="nav-link" asp-controller="Car" asp-action="List">Ilanlar</a>
                            </li>
                        </ul>
                        <ul class="navbar-nav ms-auto mt-3 mt-lg-0">
                            <li class="nav-item">
                                <a class="btn btn-sm btn-outline-light me-2" asp-controller="Account" asp-action="Login">Login</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-sm btn-primary-gradient" asp-controller="Account" asp-action="Create">Register</a>
                            </li>
                        </ul>
                    }
                </div>
            </div>
        </nav>

        <main class="container py-4 py-lg-5">
            @RenderBody()
        </main>

        <footer class="app-footer text-center">
            <div class="container">© 2026 RentalCar - Tum haklari saklidir.</div>
        </footer>
    </div>

    <partial name="_AiChatWidget" />

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
