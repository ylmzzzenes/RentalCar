@model RentalCar.ViewModels.Admin.AdminDashboardViewModel
@{
    ViewData["Title"] = "Admin Paneli";
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
    <div>
        <h2 class="mb-1">Yonetim Paneli</h2>
        <p class="text-muted mb-0">Sistem genelindeki tum islemleri buradan yonetebilirsiniz.</p>
    </div>
    <div class="d-flex flex-wrap gap-2">
        <a asp-action="Users" class="btn btn-outline-light">Kullanicilar</a>
        <a asp-action="Cars" class="btn btn-outline-light">Ilanlar</a>
        <a asp-action="Comments" class="btn btn-outline-light">Yorumlar</a>
        <a asp-action="Ratings" class="btn btn-outline-light">Puanlar</a>
        <a asp-action="Favorites" class="btn btn-outline-light">Favoriler</a>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-4">
        <div class="card bg-dark text-white border-0 h-100">
            <div class="card-body">
                <h6 class="text-uppercase text-secondary">Toplam Kullanici</h6>
                <h3 class="mb-0">@Model.TotalUsers</h3>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card bg-dark text-white border-0 h-100">
            <div class="card-body">
                <h6 class="text-uppercase text-secondary">Toplam Ilan</h6>
                <h3 class="mb-0">@Model.TotalCars</h3>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card bg-dark text-white border-0 h-100">
            <div class="card-body">
                <h6 class="text-uppercase text-secondary">Onay Bekleyen Ilan</h6>
                <h3 class="mb-0">@Model.PendingCars</h3>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card bg-dark text-white border-0 h-100">
            <div class="card-body">
                <h6 class="text-uppercase text-secondary">Yorumlar</h6>
                <h3 class="mb-0">@Model.TotalComments</h3>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card bg-dark text-white border-0 h-100">
            <div class="card-body">
                <h6 class="text-uppercase text-secondary">Puanlar</h6>
                <h3 class="mb-0">@Model.TotalRatings</h3>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card bg-dark text-white border-0 h-100">
            <div class="card-body">
                <h6 class="text-uppercase text-secondary">Favoriler</h6>
                <h3 class="mb-0">@Model.TotalFavorites</h3>
            </div>
        </div>
    </div>
</div>
