@using RentalCar.ViewModels
@model CreateViewModel

@{
    ViewData["Title"] = "Register";
}

<div class="auth-card">
    <h2 class="auth-title">Kayit Ol</h2>
    <p class="auth-subtitle">Hizli bir kayitla platformun tum ozelliklerini kullanmaya basla.</p>

    <form asp-controller="Account" asp-action="Create" method="post">
        <div asp-validation-summary="All" class="alert alert-danger py-2"></div>

        <div class="mb-3">
            <label asp-for="FullName" class="form-label">Ad Soyad</label>
            <input asp-for="FullName" class="form-control" placeholder="Adiniz Soyadiniz" />
        </div>
        <div class="mb-3">
            <label asp-for="UserName" class="form-label">Kullanici Adi</label>
            <input asp-for="UserName" class="form-control" placeholder="kullaniciadi" />
        </div>
        <div class="mb-3">
            <label asp-for="Email" class="form-label">E-posta</label>
            <input asp-for="Email" class="form-control" placeholder="ornek@mail.com" />
        </div>
        <div class="mb-3">
            <label asp-for="Password" class="form-label">Sifre</label>
            <input asp-for="Password" class="form-control" type="password" placeholder="Sifrenizi belirleyin" />
        </div>
        <div class="mb-3">
            <label asp-for="ConfirmPassword" class="form-label">Sifre Tekrar</label>
            <input asp-for="ConfirmPassword" class="form-control" type="password" placeholder="Sifrenizi tekrar girin" />
        </div>
        <button type="submit" class="btn btn-primary-gradient w-100">Register</button>
    </form>

    <div class="text-center mt-4">
        <span class="text-secondary">Zaten bir hesabin var mi?</span>
        <a asp-action="Login" class="ms-1 link-light">Login</a>
    </div>
</div>