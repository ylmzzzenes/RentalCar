@{
    ViewData["Title"] = "Sifremi Unuttum";
}

<div class="auth-card">
    <h2 class="auth-title">Sifre Sifirlama</h2>
    <p class="auth-subtitle">E-posta adresini gir, sifre yenileme baglantisini hemen gonderelim.</p>

    @if (TempData["Message"] != null)
    {
        <div class="glass-alert p-3 mb-3">@TempData["Message"]</div>
    }

    <form asp-action="ForgotPassword" method="post">
        <div class="mb-3">
            <label for="email" class="form-label">E-posta</label>
            <input id="email" name="email" type="email" class="form-control" placeholder="ornek@mail.com" required />
        </div>

        <button type="submit" class="btn btn-primary-gradient w-100">Baglanti Gonder</button>
    </form>
</div>