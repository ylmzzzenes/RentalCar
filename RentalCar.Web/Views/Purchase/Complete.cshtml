@model int
@{
    ViewData["Title"] = "Talep alındı";
}

<div class="container py-5 text-center" style="max-width:560px;">
    <h3 class="fw-bold mb-3">Satın alma talebiniz kaydedildi</h3>
    <p class="text-muted">Kayıt numaranız: <strong>#@Model</strong></p>
    <p class="small text-muted">Yönetim / satıcı süreci tamamlandığında size dönüş yapılacaktır.</p>
    <a asp-controller="CarBrowse" asp-action="List" class="btn btn-primary mt-3">İlanlara dön</a>
</div>
