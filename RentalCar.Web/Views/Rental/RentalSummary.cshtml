@model RentalCar.Domain.Entities.Rental
@using RentalCar.Domain.Enums
@{
    ViewData["Title"] = "Kiralama Ozeti";
}

<div class="card border-0 shadow-sm rounded-4 p-4">
    <h3 class="mb-3">Kiralama Ozeti</h3>
    <div class="row g-3">
        <div class="col-md-6">
            <p><strong>Arac:</strong> @(Model.Car?.CatalogBrand ?? Model.Car?.Brand) @Model.Car?.Model</p>
            <p><strong>Kiralama Turu:</strong> @Model.RentalType</p>
            <p><strong>Sure:</strong> @Model.Duration</p>
            <p><strong>Başlangıç / Bitiş (UTC):</strong> @Model.StartDate.ToString("yyyy-MM-dd") — @Model.EndDate.ToString("yyyy-MM-dd")</p>
            <p><strong>Durum:</strong> @(Model.Status switch
            {
                RentalStatus.Draft => "Taslak",
                RentalStatus.PendingConfirmation => "Onay bekliyor",
                RentalStatus.Confirmed => "Onaylandı",
                RentalStatus.Active => "Aktif",
                RentalStatus.Completed => "Tamamlandı",
                RentalStatus.Cancelled => "İptal",
                _ => Model.Status.ToString()
            })</p>
            <p><strong>Toplam Tutar:</strong> <span class="text-success fw-bold">@Model.TotalPrice.ToString("N2") TL</span></p>
        </div>
        <div class="col-md-6">
            @{
                var cover = Model.Car?.ImageUrls.FirstOrDefault(x => !string.IsNullOrWhiteSpace(x));
            }
            @if (!string.IsNullOrWhiteSpace(cover))
            {
                <img src="@(cover.StartsWith("http", StringComparison.OrdinalIgnoreCase) ? cover : Url.Content($"~/Images/Upload/{cover}"))" class="img-fluid rounded-3" style="max-height:220px; object-fit:cover;" />
            }
        </div>
    </div>

    <div class="mt-4 d-flex gap-2">
        <a asp-controller="CarBrowse" asp-action="List" class="btn btn-outline-secondary">Ilanlara Don</a>
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary">Anasayfa</a>
    </div>
</div>
