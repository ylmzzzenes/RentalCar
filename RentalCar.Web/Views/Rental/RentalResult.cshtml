@model RentalCar.Domain.Entities.Rental
@using RentalCar.Domain.Enums

@{
    ViewData["Title"] = "Kiralama Sonucu";
}

<div class="card shadow-sm border-0 p-4">
    <h2 class="mb-4">Kiralama Sonucu</h2>

    <div class="row g-4">
        <div class="col-md-6">
            <h4>@Model.Car.Brand @Model.Car.Model</h4>
            <p><strong>Plaka:</strong> @Model.Car.Plate</p>
            <p><strong>Yıl:</strong> @Model.Car.ModelYear</p>
            <p><strong>Yakıt Türü:</strong> @Model.Car.FuelType.GetDisplayName()</p>
            <p><strong>Vites:</strong> @Model.Car.Transmission.GetDisplayName()</p>
            <p><strong>Kasa Tipi:</strong> @Model.Car.BodyType.GetDisplayName()</p>
            <p><strong>Renk:</strong> @Model.Car.Color</p>

            <p><strong>Kiralama Tipi:</strong> @Model.RentalType</p>
            <p><strong>Süre:</strong> @Model.Duration</p>
            <p><strong>Başlangıç (UTC):</strong> @Model.StartDate.ToString("yyyy-MM-dd")</p>
            <p><strong>Bitiş (UTC):</strong> @Model.EndDate.ToString("yyyy-MM-dd")</p>
            <p><strong>Durum:</strong> @(Model.Status switch
            {
                RentalStatus.Draft => "Taslak",
                RentalStatus.PendingConfirmation => "Onay bekliyor",
                RentalStatus.Confirmed => "Onaylandı",
                RentalStatus.Active => "Aktif",
                RentalStatus.Completed => "Tamamlandı",
                RentalStatus.Cancelled => "İptal",
                _ => Model.Status.ToString()
            })</p>
            <p><strong>Toplam Ücret:</strong> <span class="text-success fw-bold">@Model.TotalPrice ₺</span></p>

            <div class="mt-3">
                <a asp-controller="CarBrowse" asp-action="List" class="btn btn-outline-secondary">← Araba Listesine Dön</a>
            </div>
        </div>

        <div class="col-md-6 text-center">
            @if (Model.Car.ImageUrls.Any(x => !string.IsNullOrWhiteSpace(x)))
            {
                foreach (var img in Model.Car.ImageUrls.Where(x => !string.IsNullOrWhiteSpace(x)))
                {
                    <img src="@(img.StartsWith("http", StringComparison.OrdinalIgnoreCase) ? img : Url.Content($"~/Images/Upload/{img}"))"
                         class="img-thumbnail m-2"
                         style="max-height: 200px; object-fit: cover;" />
                }
            }
            else
            {
                <p>Bu araca ait görsel bulunmamaktadır.</p>
            }
        </div>
    </div>
</div>
