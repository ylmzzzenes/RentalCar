@{
    ViewData["Title"] = "Hos Geldiniz";
}

<div class="auth-hero text-center mx-auto" style="max-width: 820px;">
    <h1 class="auth-title">RentalCar'a Hos Geldiniz</h1>
    <p class="auth-subtitle">
        Devam etmek icin lutfen bir secim yapin. Hesabiniz varsa giris yapin, yoksa hemen kayit olun.
    </p>

    <div class="d-flex flex-column flex-md-row justify-content-center gap-3 mt-4">
        <a asp-controller="Account" asp-action="Login" class="btn btn-outline-light btn-lg px-4">
            Login
        </a>
        <a asp-controller="Account" asp-action="Create" class="btn btn-primary-gradient btn-lg px-4">
            Register
        </a>
    </div>
</div>
