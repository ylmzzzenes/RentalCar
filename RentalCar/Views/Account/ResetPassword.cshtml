@using RentalCar.ViewModels
@model ResetPasswordModel

@{
    ViewData["Title"] = "Parola Sifirlama";
}

<div class="auth-card">
    <h2 class="auth-title">Parola Yenile</h2>
    <p class="auth-subtitle">Yeni parolani belirleyip guvenli sekilde hesabina giris yapabilirsin.</p>

    <form asp-action="ResetPassword" method="post">
        <div asp-validation-summary="All" class="alert alert-danger py-2"></div>
        <input type="hidden" asp-for="Token" />

        <div class="mb-3">
            <label asp-for="Email" class="form-label">E-posta</label>
            <input asp-for="Email" class="form-control" placeholder="ornek@mail.com" />
        </div>
        <div class="mb-3">
            <label asp-for="Password" class="form-label">Yeni Sifre</label>
            <input asp-for="Password" type="password" class="form-control" />
        </div>
        <div class="mb-4">
            <label asp-for="ConfirmPassword" class="form-label">Yeni Sifre Tekrar</label>
            <input asp-for="ConfirmPassword" type="password" class="form-control" />
        </div>

        <button type="submit" class="btn btn-primary-gradient w-100">Sifreyi Guncelle</button>
    </form>
</div>