@using RentalCar.ViewModels
@model LoginViewModel

@{
    ViewData["Title"] = "Login";
}

<div class="auth-card">
    <h2 class="auth-title">Giris Yap</h2>
    <p class="auth-subtitle">Hesabina giris yaparak araclari hemen incelemeye basla.</p>

    <form asp-action="Login" method="post">
        <div asp-validation-summary="All" class="alert alert-danger py-2"></div>

        <div class="mb-3">
            <label asp-for="Email" class="form-label">E-posta</label>
            <input asp-for="Email" class="form-control" placeholder="ornek@mail.com" />
        </div>

        <div class="mb-3">
            <label asp-for="Password" class="form-label">Sifre</label>
            <input asp-for="Password" class="form-control" type="password" placeholder="Sifrenizi girin" />
        </div>

        <div class="form-check mb-3">
            <input asp-for="RememberMe" class="form-check-input" />
            <label asp-for="RememberMe" class="form-check-label">Beni hatirla</label>
        </div>

        <div class="d-grid gap-2">
            <button type="submit" class="btn btn-primary-gradient">Login</button>
            <a asp-action="ForgotPassword" class="btn btn-outline-light">Sifremi Unuttum</a>
        </div>
    </form>

    <div class="text-center mt-4">
        <span class="text-secondary">Hesabin yok mu?</span>
        <a asp-action="Create" class="ms-1 link-light">Register</a>
    </div>
</div>