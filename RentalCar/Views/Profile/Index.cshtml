@model RentalCar.ViewModels.ProfileViewModel
@{
    ViewData["Title"] = "Profilim";
}

<div class="row g-4">
    <div class="col-lg-4">
        <div class="auth-card text-center">
            <img src="@(string.IsNullOrWhiteSpace(Model.ProfileImageUrl) ? "https://via.placeholder.com/220x220?text=Profil" : Url.Content($"~/Images/Profile/{Model.ProfileImageUrl}"))"
                 class="rounded-circle mb-3 shadow"
                 style="width:180px; height:180px; object-fit:cover;" />
            <h5 class="mb-1">@Model.FullName</h5>
            <div class="text-muted small">@Model.UserName</div>
            <p class="mt-3 text-muted small">@(string.IsNullOrWhiteSpace(Model.Bio) ? "Henüz biyografi eklenmemiş." : Model.Bio)</p>
        </div>
    </div>
    <div class="col-lg-8">
        <div class="auth-card">
            <h4 class="auth-title">Profil Bilgileri</h4>
            @if (TempData["Message"] != null)
            {
                <div class="alert alert-success py-2">@TempData["Message"]</div>
            }
            <form asp-action="Update" method="post" enctype="multipart/form-data">
                <div asp-validation-summary="All" class="alert alert-danger py-2"></div>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="FullName" class="form-label"></label>
                        <input asp-for="FullName" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="UserName" class="form-label"></label>
                        <input asp-for="UserName" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Email" class="form-label"></label>
                        <input asp-for="Email" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Profil Fotografi</label>
                        <input type="file" name="profileImage" class="form-control" accept="image/*" />
                    </div>
                    <div class="col-12">
                        <label asp-for="Bio" class="form-label"></label>
                        <textarea asp-for="Bio" class="form-control" rows="4"></textarea>
                    </div>
                </div>
                <button class="btn btn-primary-gradient mt-3">Profili Guncelle</button>
            </form>
        </div>
    </div>
</div>
