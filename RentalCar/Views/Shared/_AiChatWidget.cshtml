<div id="ai-chat-widget" class="ai-chat-widget">
    <button id="ai-chat-toggle" type="button" class="ai-chat-toggle">AI Asistan</button>
    <div id="ai-chat-panel" class="ai-chat-panel d-none">
        <div class="ai-chat-header">
            <strong>RentalCar AI Assistant</strong>
            <button id="ai-chat-close" type="button" class="btn btn-sm btn-outline-light">Kapat</button>
        </div>
        <div id="ai-chat-messages" class="ai-chat-messages">
            <div class="ai-bubble ai-bubble-assistant">
                Merhaba! Dogal dille arac arayabilir, fiyat karsilastirmasi isteyebilirsin.
            </div>
        </div>
        <div id="ai-chat-cars" class="ai-chat-cards"></div>
        <div class="ai-chat-input-wrap">
            <form id="ai-chat-form">
                @Html.AntiForgeryToken()
                <div class="input-group">
                    <input id="ai-chat-input" class="form-control" maxlength="1000" placeholder="Ornek: 3 gunluk Istanbul'da ucuz SUV bul" />
                    <button class="btn btn-primary-gradient" type="submit">Gonder</button>
                </div>
            </form>
            <button id="ai-apply-filters" type="button" class="btn btn-outline-light btn-sm mt-2 d-none">
                Filtreyi Ilanlara Uygula
            </button>
        </div>
    </div>
</div>
