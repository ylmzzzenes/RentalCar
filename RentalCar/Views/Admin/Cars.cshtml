@model List<RentalCar.ViewModels.Admin.AdminCarItemViewModel>
@{
    ViewData["Title"] = "Ilan Yonetimi";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Ilan Yonetimi</h2>
    <a asp-action="Dashboard" class="btn btn-outline-light btn-sm">Panele Don</a>
</div>

<div class="table-responsive">
    <table class="table table-dark table-hover align-middle">
        <thead>
            <tr>
                <th>ID</th>
                <th>Ilan</th>
                <th>Fiyat</th>
                <th>Yil</th>
                <th>Sehir</th>
                <th>Durum</th>
                <th class="text-end">Islemler</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var car in Model)
            {
                <tr>
                    <td>@car.Id</td>
                    <td>
                        <a asp-controller="Car" asp-action="Details" asp-route-id="@car.Id" class="link-light text-decoration-none fw-semibold">
                            @car.Title
                        </a>
                    </td>
                    <td>@(car.Price?.ToString("N0") ?? "-") TL</td>
                    <td>@(car.Year?.ToString() ?? "-")</td>
                    <td>@(car.City ?? "-")</td>
                    <td>
                        @if (car.IsApproved)
                        {
                            <span class="badge text-bg-success">Yayinda</span>
                        }
                        else
                        {
                            <span class="badge text-bg-warning">Beklemede</span>
                        }
                    </td>
                    <td class="text-end">
                        <div class="d-inline-flex gap-2">
                            <form asp-action="ToggleApprove" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@car.Id" />
                                <button class="btn btn-sm @(car.IsApproved ? "btn-warning" : "btn-success")" type="submit">
                                    @(car.IsApproved ? "Pasife Al" : "Onayla")
                                </button>
                            </form>
                            <form asp-action="DeleteCar" method="post" onsubmit="return confirm('Ilani silmek istediginize emin misiniz?');">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@car.Id" />
                                <button class="btn btn-sm btn-danger" type="submit">Sil</button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
